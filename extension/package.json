{
  "name": "kiro-skills-loader",
  "displayName": "Kiro Skills Loader",
  "description": "Maintain a hierarchical skills library and install all of them into Kiro's flat skills folder so Kiro auto-activates them by description matching.",
  "version": "0.2.0",
  "publisher": "local",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "configuration": {
      "title": "Kiro Skills Loader",
      "properties": {
        "kiroSkills.skillsRoot": {
          "type": "string",
          "default": "SKILLS",
          "description": "Workspace-relative path to the skills root folder (the deep, hierarchical library)."
        },
        "kiroSkills.companionFolders": {
          "type": "array",
          "items": { "type": "string" },
          "default": [
            "references", "examples", "tutorials", "scripts", "evals",
            "assets", "resources", "templates", "docs", "fixtures", "samples"
          ],
          "description": "Folder names treated as companion content next to SKILL.md."
        },
        "kiroSkills.userSkillsRoot": {
          "type": "string",
          "default": "~/.kiroskills",
          "description": "User-level master library (deep hierarchy preserved). This is NOT where Kiro looks for skills — see installScope. Use ~ for the home directory."
        },
        "kiroSkills.syncToUserOnRefresh": {
          "type": "boolean",
          "default": true,
          "description": "On every refresh, copy any new skills into the user library. Never deletes."
        },
        "kiroSkills.installScope": {
          "type": "string",
          "enum": ["global", "workspace"],
          "default": "global",
          "description": "Where to install skills so Kiro can discover them. global = ~/.kiro/skills (all workspaces). workspace = <ws>/.kiro/skills (this project only)."
        },
        "kiroSkills.autoInstall": {
          "type": "boolean",
          "default": true,
          "description": "Auto-toggle install when the trigger word is present in the active document."
        },
        "kiroSkills.triggerWord": {
          "type": "string",
          "default": "SKILLS",
          "description": "Whole-word, case-sensitive trigger that toggles install/uninstall. Edge-triggered."
        }
      }
    },
    "commands": [
      {
        "command": "kiroSkills.refresh",
        "title": "Skills: Refresh Index",
        "icon": "$(refresh)"
      },
      {
        "command": "kiroSkills.openSkill",
        "title": "Skills: Open SKILL.md"
      },
      {
        "command": "kiroSkills.toggleForActiveFile",
        "title": "Skills: Toggle Install (uses current scope)",
        "icon": "$(symbol-event)"
      },
      {
        "command": "kiroSkills.installAll",
        "title": "Skills: Install All Into Kiro Skills Folder"
      },
      {
        "command": "kiroSkills.uninstallAll",
        "title": "Skills: Uninstall All From Kiro Skills Folder"
      },
      {
        "command": "kiroSkills.searchByKeyword",
        "title": "Skills: Search by Keyword"
      },
      {
        "command": "kiroSkills.syncToUser",
        "title": "Skills: Sync Workspace To User Library"
      },
      {
        "command": "kiroSkills.openUserFolder",
        "title": "Skills: Open User Library Folder"
      },
      {
        "command": "kiroSkills.openKiroSkillsFolder",
        "title": "Skills: Open Kiro Install Folder"
      }
    ],
    "keybindings": [
      {
        "command": "kiroSkills.toggleForActiveFile",
        "key": "ctrl+alt+s",
        "mac": "cmd+alt+s",
        "when": "editorTextFocus"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kiroSkills",
          "title": "Skills",
          "icon": "$(book)"
        }
      ]
    },
    "views": {
      "kiroSkills": [
        {
          "id": "kiroSkills.tree",
          "name": "Skill Library"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "kiroSkills.refresh",
          "when": "view == kiroSkills.tree",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "kiroSkills.openSkill",
          "when": "view == kiroSkills.tree && viewItem == skill",
          "group": "1_open"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --no-dependencies --allow-missing-repository --out kiro-skills-loader.vsix"
  },
  "devDependencies": {
    "@types/node": "20.11.0",
    "@types/vscode": "1.85.0",
    "@vscode/vsce": "2.24.0",
    "typescript": "5.4.5"
  }
}
